<%- include('partials/header') %>

<div class="booking-container" style="max-width: 600px; margin: 2rem auto;">
    <div class="options-panel">
        <h3 style="margin-bottom: 1.5rem; text-align: center;">My Profile</h3>

        <% if (locals.success) { %>
            <div style="background: rgba(34, 197, 94, 0.1); border: 1px solid #22c55e; color: #22c55e; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; text-align: center;">
                <%= success %>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid var(--danger); color: var(--danger); padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; text-align: center;">
                <%= error %>
            </div>
        <% } %>

        <div style="text-align: center; margin-bottom: 2rem;">
            <% if (user.avatar) { %>
                <img src="<%= user.avatar %>" alt="Profile Picture" style="width: 100px; height: 100px; border-radius: 50%; border: 3px solid var(--primary);">
            <% } else { %>
                <i class="fa-solid fa-user-circle" style="font-size: 5rem; color: var(--primary);"></i>
            <% } %>
            <h2 style="margin-top: 1rem;"><%= user.name %></h2>
            <p style="color: var(--text-muted);"><%= user.email %></p>
        </div>

        <hr style="border: 1px solid var(--border-color); margin-bottom: 1.5rem;">

        <h4 style="margin-bottom: 1rem;">Change Password</h4>
        <form action="/profile/change-password" method="POST">
            <% if (user.password) { %>
            <div class="form-group">
                <label>Current Password</label>
                <input type="password" name="currentPassword" class="form-control" required placeholder="Enter current password">
            </div>
            <% } %>
            
            <div class="form-group">
                <label>New Password</label>
                <input type="password" name="newPassword" class="form-control" required placeholder="Enter new password">
            </div>
            
            <div class="form-group">
                <label>Confirm New Password</label>
                <input type="password" name="confirmPassword" class="form-control" required placeholder="Confirm new password">
            </div>
            
            <button type="submit" class="btn btn-primary" style="width: 100%;">Update Password</button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>
